#!/usr/bin/env zsh
set -euo pipefail

{{ include "scripts/lib/log.sh" }}

# GITHUB_TOKEN comes from sops exec-env
if (( $+commands[gh] )) && [[ -n "${GITHUB_TOKEN:-}" ]]; then
  log_step "gh auth login..."
  if gh auth status &>/dev/null; then
    log_info "gh auth status: already logged in"
  else
    echo "$GITHUB_TOKEN" | gh auth login --with-token
    log_success "gh auth login successful"
  fi

  log_step "Install gh extensions..."
  gh extension install dlvhdr/gh-dash
fi

# vim: ft=zsh
