{
  "agentPushNotifEnabled": true,
  "disableArtifact": true,
  "disableBundledSkills": true,
  "disableClaudeAiConnectors": true,
  "disableRemoteControl": true,
  "disableWorkflows": true,
  "enabledPlugins": {
    "caveman@caveman": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "repo": "JuliusBrussee/caveman",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "if command -v osascript >/dev/null 2>&1; then osascript -e 'display notification \"Task completed or needs input\" with title \"Claude Code\"'; elif command -v notify-send >/dev/null 2>&1; then notify-send 'Claude Code' 'Task completed or requires input'; fi",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "deny": [
      "AskUserQuestion",
      "CronCreate",
      "CronDelete",
      "CronList",
      "DesignSync",
      "EnterPlanMode",
      "ExitPlanMode",
      "NotebookEdit",
      "PushNotification",
      "RemoteTrigger",
      "ReportFindings",
      "ScheduleWakeup",
      "SendMessage"
    ]
  },
  "remoteControlAtStartup": false,
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  },
  "tui": "fullscreen"
}
